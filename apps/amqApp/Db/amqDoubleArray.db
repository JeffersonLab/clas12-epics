record(waveform,"$(P)"){
  field(DTYP,"AMQR")
  field(INP,"$(K)")
  field(NELM,"$(N)")
  field(FTVL,"DOUBLE")
  field(DESC,"")
#  field(FLNK,"$(P)-DF")
}

record(dfanout, "$(P)-DF"){
  field(DOL,"0")
  field(OUTA,$(P)-Time)
  }

record(calc,"$(P)-Time") {
  field(DESC,"")
  field(CALC,"VAL+1")
  field(SCAN, "1 second")
  field(HIHI, "$(THH=30)")
  field(HIGH, "$(TH=15)")
  field(HHSV, "$(HHSV=NO_ALARM)")
  field(HSV, "$(HSV=NO_ALARM)")
}
