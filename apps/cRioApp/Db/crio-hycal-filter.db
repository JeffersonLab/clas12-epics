
record(bo,"B_PRAD_HYCAL_ADV") {
	field(DESC,"Advance to the next filter setting")
}
record(bo,"B_PRAD_HYCAL_SETPOS") {
	field(DESC,"Set the filter position")
}
record(ai,"B_PRAD_HYCAL_FILTPOST_SET") {
	field(DESC,"Filter position setpoint")
	field(PREC,"0")
	info(autosaveFields_pass0,"HIHI HIGH LOW LOLO HHSV HSV LSV LLSV")
}
record(ai,"B_PRAD_HYCAL_FILTERPOS") {
	field(DESC,"Filter position readback")
	field(PREC,"0")
	info(autosaveFields_pass0,"HIHI HIGH LOW LOLO HHSV HSV LSV LLSV")
}
record(bi,"B_PRAD_HYCAL_INPOS") {
	field(DESC,"Filter in position")
	info(autosaveFields_pass0,"ZSV OSV")
}
record(bi,"B_PRAD_HYCAL_HOME") {
	field(DESC,"Filter at home")
	info(autosaveFields_pass0,"ZSV OSV")
}
