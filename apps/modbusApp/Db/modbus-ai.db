record(ai,"$(P)$(R)") {
    field(SCAN,"$(SCAN=I/O Intr)")
    field(INP,"@asyn($(PORT),$(OFFSET=0))$(DATA_TYPE=FLOAT32_BE)")
    field(DTYP,"asynFloat64")
    field(PREC,"$(PREC=2)")
    field(EGU,"$(EGU=)")
    field(DESC,"$(DESC=)")
    info(autosaveFields_pass0,"LOLO LOW HIGH HIHI LLSV LSV HSV HHSV")
}
