record(bi, "$(P)$(R)") {
    field(SCAN,"$(SCAN=I/O Intr)")
    field(INP,"@asyn($(PORT),$(OFFSET))$(DATA_TYPE=UINT16)")
    field(DTYP,"asynInt32")
    field(ZNAM,"$(ZNAM=Off)")
    field(ONAM,"$(ONAM=On)")
    field(ZSV,"$(ZSV=NO_ALARM)")
    field(OSV,"$(OSV=NO_ALARM)")
    field(DESC,"$(DESC=)")
}
