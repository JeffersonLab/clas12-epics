    <transparent>true</transparent>
    <auto_size>true</auto_size>
    <text>12,800 steps = 800 enc = 1 rev&#xD;
&#xD;
X: 22,868.28 steps/mm&#xD;
    increasing step value = beam left&#xD;
    safe = 91,200 from center = 174,414&#xD;
&#xD;
Z: 22,868.28 steps/mm&#xD;
    increasing step value = upstream&#xD;
    safe = 68,400 from center = 236,825&#xD;
&#xD;
Y: 1 mm = 81,268 steps&#xD;
     increasing step value = up&#xD;
&#xD;
f: increasing step value = rotate clockwise&#xD;
   viewed from above&#xD;
   upst end moves beam left</text>
    <scripts />
    <height>272</height>
    <border_width>1</border_width>
