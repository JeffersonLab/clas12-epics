        <scriptText><![CDATA[from org.csstudio.opibuilder.scriptUtil import PVUtil
from javax.swing import JOptionPane
import time


pv_name = "TGT:PRad:Mtr_Stop"
#pvs = [PVUtil.createPV(pv_name, widget)]


# 1. Set to 1
PVUtil.writePV("TGT:PRad:Mtr_Stop",1)
    
