        <scriptText><![CDATA[from org.csstudio.opibuilder.scriptUtil import PVUtil
from javax.swing import JOptionPane
import time

# --- Configuration ---
pv_name = "TGT:PRad:X_Center"
pvs = [PVUtil.createPV(pv_name, widget)]
# ---------------------

# 1. Ask for confirmation
confirm = JOptionPane.showConfirmDialog(None, 
    "Are you sure you want to set " + pv_name + " to 1?", 
    "Confirm Action", 
    JOptionPane.YES_NO_OPTION)

if confirm == JOptionPane.YES_OPTION:
    # 2. Set to 1
    pvs[0].setValue(1)
    
    # 3. Wait for 1 second
    time.sleep(1)
    
    # 4. Set back to 0
    pvs[0].setValue(0)
    print("Action completed.")
else:
    print("Action cancelled.")
]]></scriptText>
        <embedded>true</embedded>
        <description></description>
      </action>
