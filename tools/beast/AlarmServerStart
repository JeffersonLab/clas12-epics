#!/bin/sh

export JAVA_HOME=/usr/clas12/third-party-libs/jdk/1.8.0_31
export PATH=$JAVA_HOME/bin:$PATH

EXE_DIR=/usr/clas12/css/4.3.3/linux-x86_64/bin
INI_DIR=/usr/clas12/epics/el9/clas12/tools/beast
XML_DIR=/usr/clas12/epics/el9/clas12/apps/beast

if [ "$1" != "" ]; then
    ROOT=$1
else
    systemd-notify --status "Usage: $0 <root>"
    exit
fi

$EXE_DIR/AlarmServer -root $ROOT -pluginCustomization $INI_DIR/alarm_settings.ini
